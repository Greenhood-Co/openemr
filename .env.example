# Copy to .env and set strong secrets before running Compose.
#   cp .env.example .env

COMPOSE_PROJECT_NAME=greenhood-openemr

# Leave unset until blue is installed and healthy. Starting openemr_green during first-time setup
# races auto_configure on the shared sites volume.
# COMPOSE_PROFILES=standby

# DB host for OpenEMR containers. Default 172.29.8.10 matches the static IP in docker-compose.yml.
# Set to mysql only if Docker embedded DNS works reliably on your host.
# OPENEMR_MYSQL_HOST=172.29.8.10

# MariaDB (internal only — not published to the host)
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=openemr
MYSQL_PASS=change-me-openemr-db
MYSQL_DATABASE=openemr
# MYSQL_PASS is passed to the MariaDB image as MYSQL_PASSWORD so the openemr user exists on first boot.

# If MariaDB logs show "Access denied for user 'openemr'@'172.29.x.x'", MYSQL_PASS does not match
# the DB (e.g. you changed .env but kept mariadb_data). Align MYSQL_PASS with the server, or as root:
#   ALTER USER 'openemr'@'%' IDENTIFIED BY 'same-as-MYSQL_PASS'; FLUSH PRIVILEGES;
# Or clean slate: docker compose down -v  (destroys DB + sites — only if no data to keep).

# Initial OpenEMR admin (auto-install). Login username / password.
OE_USER=owner
OE_PASS=change-me-admin-password
# Shown as the user’s first name in OpenEMR after install (optional).
OE_ADMIN_DISPLAY_NAME=Greenhood_co

# Shared password for Greenhood training accounts (provision_training_users.php). Not hardcoded in source.
# Use a strong value in production-like environments.
TRAINING_ACCOUNT_PASSWORD=change-me-training-password

# Published port for the compose Nginx reverse proxy (OpenEMR app containers are not published).
NGINX_HTTP_PORT=80

# Image tag for the custom image built from ./Dockerfile
OPENEMR_IMAGE_NAME=greenhood-openemr
OPENEMR_IMAGE_TAG=local

# Optional: path to active-backend.conf for deploy.sh (default: docker/greenhood/nginx/active-backend.conf)
# ACTIVE_BACKEND_CONF=/path/to/active-backend.conf
