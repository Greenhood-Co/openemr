# Copy to .env and set strong secrets before running Compose on the VPS.
#   cp .env.example .env

COMPOSE_PROJECT_NAME=greenhood-openemr

# MariaDB (internal only — not published to the host)
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=openemr
MYSQL_PASS=change-me-openemr-db
MYSQL_DATABASE=openemr

# Initial OpenEMR admin (auto-install). Login username / password.
OE_USER=owner
OE_PASS=change-me-admin-password
# Shown as the user’s first name in OpenEMR after install (optional).
OE_ADMIN_DISPLAY_NAME=Greenhood_co

# Loopback ports so *host* nginx can proxy to Docker (must match upstream in sites-enabled file).
OPENEMR_BLUE_HOST_PORT=18081
OPENEMR_GREEN_HOST_PORT=18082

# deploy.sh only edits this vhost (default). Override if your path differs.
# NGINX_SITE_CONF=/etc/nginx/sites-enabled/openemr.greenhood.com.ng

# Image tag for the custom image built from ./Dockerfile
OPENEMR_IMAGE_NAME=greenhood-openemr
OPENEMR_IMAGE_TAG=local
